LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Dispatch name the worker registers under (agent.py) and the dialer targets
# (telephony/dial.py). Leave unset in the cloud/prod deploy to use the default
# "my-agent". For local dev, set a unique name (e.g. my-agent-dev) so your
# `agent.py dev` worker never collides with the deployed cloud agent.
AGENT_NAME=

# Telephony (outbound via Plivo). Not managed by LiveKit, so `lk app env` can't
# fetch these — set them manually.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
PLIVO_NUMBER=
SARVAM_API_KEY=

# AWS Bedrock — conversation LLM (Claude Haiku 4.5, ap-south-1/Mumbai). Set
# AWS_ACCESS_KEY_ID to enable Bedrock; leave unset to use the OpenRouter
# fallback. In ap-south-1 the latest Claude is served via the Global
# cross-region inference profile (the "global." prefix).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
BEDROCK_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
